# ---- ImmoCalc .env (wie jFlow) · LIVE + DEV --------------------------------
# Kopiere zu .env (NICHT committen – ist in .gitignore).

# Ports der Web-UIs
DASHBOARD_PORT=8091          # LIVE
DASHBOARD_PORT_DEV=8092      # DEV

TZ=Europe/Berlin
LOG_LEVEL=INFO
LOG_LEVEL_DEV=DEBUG
PUID=99
PGID=100

# WICHTIG: Laufzeit-/Nutzerdaten liegen AUSSERHALB des Git-Clones.
# Der Clone liegt unter /mnt/user/appdata/immocalc – Daten daneben:
CONFIG_DIR=/mnt/user/appdata/immocalc-live
DATA_DIR=/mnt/user/appdata/immocalc-live/data
CONFIG_DIR_DEV=/mnt/user/appdata/immocalc-dev
DATA_DIR_DEV=/mnt/user/appdata/immocalc-dev/data

GIT_SHA=local
