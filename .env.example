# ---- ImmoCalc .env (wie jFlow) -----------------------------
# Kopiere zu .env (NICHT committen – ist in .gitignore).

# Ports der Web-UIs
DASHBOARD_PORT=8091

TZ=Europe/Berlin
LOG_LEVEL=INFO
PUID=99
PGID=100

# WICHTIG: Laufzeit-/Nutzerdaten liegen AUSSERHALB des Git-Clones.
# Der Clone liegt unter /mnt/user/appdata/immocalc – Daten daneben:
CONFIG_DIR=/mnt/user/appdata/immocalc-live
DATA_DIR=/mnt/user/appdata/immocalc-live/data

GIT_SHA=local

# ---- KI-Beleg-Auslese (CCLXVIII) — OPTIONAL --------------------------------
# Ohne Key läuft alles wie bisher, nur ohne KI: die regelbasierte Heuristik
# erkennt Datum und Betrag allein. Mit gesetztem Key liest ein günstiges
# Claude-Modell den OCR-Text und zieht Kopf-/Rechnungsdatum, Betrag und eine
# Klassifizierung zuverlässiger heraus.
# ACHTUNG Datenschutz: der Belegtext (echte Namen, IBANs, Beträge) wird dann an
# die Anthropic-API gesendet. Opt-in — nur setzen, wenn das gewollt ist.
ANTHROPIC_API_KEY=
# Das genutzte Modell — Vorgabe ist das kleinste/günstigste. Selten zu ändern.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
