# --- Secrets / lokale Konfiguration (NIE committen) ---
.env
*.env.local

# --- Laufzeit-/Nutzerdaten: echte Mieter-/Objektdaten, DB, Belege ---
# (liegen standardmäßig AUSSERHALB des Repos unter appdata/immocalc-live|-dev,
#  hier zusätzlich als Sicherheitsnetz falls jemand im Repo-Baum arbeitet)
data/
/data/
*.db
*.sqlite
*.sqlite3
uploads/
uploads
belege/
belege
*.pdf.scan
# Echter Dokumentenbestand des Nutzers, zur Analyse in den Repo-Baum kopiert.
# Enthaelt Mietvertraege, Kontoauszuege, Namen — gehoert niemals ins Git.
immo_DATA/
unterlagen/

# --- Build / Tooling ---
build.txt
node_modules/
# JEDER screenshots-Ordner (Test-Artefakte) auf jeder Ebene — nicht nur
# tests/screenshots, sondern auch api/tests/screenshots. Ohne Wurzel-Anker,
# sonst rutschen Prüfstand-Screenshots (evtl. mit echten Daten) doch ins Git.
screenshots/
tests/screenshots/
__pycache__/
*.pyc
.pytest_cache/

# --- OS ---
.DS_Store

# Wegwerf-Skripte des Agents
scratch/
node_modules/
tests/screenshots/

# Laufzeit-Dateien des Auto-Updaters (dürfen den Pull nicht blockieren)
tools/auto-update.log
tools/.auto-update.lock
tools/.zuletzt-deployt

# OCR-Nachzieh-Bericht (CLXXIX): kann echte Betraege/Namen aus Belegen tragen
